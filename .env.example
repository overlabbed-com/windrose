# Vane Authentication Service Environment Variables

# Required
SESSION_SECRET=your-256-bit-secret-key-minimum-32-characters

# Optional - for key rotation
# SESSION_SECRET_ROTATION=your-old-256-bit-secret-key-for-rotation

# Optional - for API key verification
# API_KEY_SECRET=your-api-key-secret

# Redis connection (defaults to localhost)
REDIS_URL=redis://localhost:6379

# Google OAuth2 (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-app.com/api/auth/oauth/google/callback

# OAuth success redirect (after login)
OAUTH_SUCCESS_REDIRECT_URL=/